# ===== CẤU HÌNH MÁY CHỦ =====
PORT=3000

# ===== MẬT KHẨU TRANG QUẢN TRỊ =====
# Đổi mật khẩu này trước khi deploy! Đây là mật khẩu duy nhất để đăng nhập /admin
ADMIN_PASSWORD=admin123

# ===== KHOÁ MÃ HOÁ SESSION =====
# Một chuỗi bí mật bất kỳ, càng dài càng random càng tốt. Dùng để ký cookie đăng nhập.
# Có thể tạo nhanh bằng lệnh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=thay-doi-chuoi-bi-mat-nay

# ===== ĐƯỜNG DẪN TRANG QUẢN TRỊ (tuỳ chọn) =====
# Đổi sang một đường dẫn khó đoán hơn nếu muốn thêm 1 lớp bảo mật ẩn danh.
# Ví dụ: ADMIN_PATH=/quanly-bimat-xyz
ADMIN_PATH=/admin

# ===== THƯ MỤC LƯU DỮ LIỆU (tuỳ chọn) =====
# Nếu deploy lên Render/Railway và có gắn Persistent Disk/Volume, hãy đổi
# đường dẫn này thành điểm gắn (mount path) của ổ đĩa đó để dữ liệu không mất khi redeploy.
DATA_DIR=./data
